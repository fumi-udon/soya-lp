            const $inputs = $('.input-soya');
            const $scroller = $('.photo-scroller');

            // --- 1. 麺の躍動感演出 ---
            $inputs.on('focus', function() {
                $scroller.css('animation-duration', '20s'); // 背景加速
            }).on('blur', function() {
                $scroller.css('animation-duration', '60s'); // 減速
